---
# Ansible Lint configuration for the local-infra k3s bootstrap.
# https://ansible-lint.readthedocs.io/en/latest/configuring.html

skip_list:
  # The k3s install uses the official `curl -sfL https://get.k3s.io | sh`
  # method, which is the documented, canonical install path and cannot be
  # expressed with the get_url/uri modules.
  - command-instead-of-get_url